@model chaves_dayron_proyecto2_3101.Models.extra

@{
    ViewBag.Title = "Nueva Extra";
    string currentDate = DateTime.Today.ToString("yyyy-MM-dd");
}

<h2>Añadir nueva extra</h2>


@using (Html.BeginForm("AddExtra", "Home", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })


        @Html.HiddenFor(model => model.empleado_id)

        <div class="form-group">
            @Html.LabelFor(model => model.fecha, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.fecha, new { htmlAttributes = new { @class = "form-control", @Type = "date", @Min = @currentDate } })
            </div>
            @Html.ValidationMessageFor(model => model.fecha, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.motivo, htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.TextAreaFor(model => model.motivo, new { htmlAttributes = new { @class = "form-control" } })
            </div>
            @Html.ValidationMessageFor(model => model.motivo, "", new { @class = "text-danger" })
        </div>

        <br />

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Asignar Extra" class="btn btn-primary btn-md" />
            </div>
            <a style="color:red"><small><i>Esta accion se reportará.</i></small></a>
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
