@using chaves_dayron_proyecto2_3101.Models
@model Tuple<List<puesto>, porcentaje>

@{
    ViewBag.Title = "Salario";
}

<h2>Ajuste de Nomina</h2>

@using (Html.BeginForm("Salario", "Home", FormMethod.Post))
{
    @Html.AntiForgeryToken()

<div class="form-horizontal">
    <hr />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <!--For each puesto-->

    @for (int i = 0; i < @Model.Item1.Count; i++)
    {
        @Html.Hidden("Item1["+i+"].puesto_id", Model.Item1[i].puesto_id)

        <div class="form-group">
            @Html.Label(Model.Item1[i].descripcion, htmlAttributes: new { @class = "control-label col-md-20" })
            <div class="col-md-10">
                @Html.EditorFor(model => model.Item1[i].salario, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(model => model.Item1[i].salario, "", new { @class = "text-danger" })
            </div>
        </div>
    }

    <div class="form-group">
        @Html.LabelFor(model => @Model.Item2.extra_bonificacion, htmlAttributes: new { @class = "control-label col-md-20" })
        <div class="col-md-10">
            @Html.EditorFor(model => @Model.Item2.extra_bonificacion, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => @Model.Item2.extra_bonificacion, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(model => @Model.Item2.libre_deduccion, htmlAttributes: new { @class = "control-label col-md-20" })
        <div class="col-md-10">
            @Html.EditorFor(model => @Model.Item2.libre_deduccion, new { htmlAttributes = new { @class = "form-control" } })
            @Html.ValidationMessageFor(model => @Model.Item2.libre_deduccion, "", new { @class = "text-danger" })
        </div>
    </div>

    <br />

    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <input type="submit" value="Aplicar Cambios" class="btn btn-primary btn-md" />
        </div>
    </div>
</div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script src="/Scripts/jquery-3.7.1.min.js" type="text/javascript"></script>
    <script type="text/javascript">
        $(document).ready(function () {
            $("input[type='text']").val(function (index, value) {
                return value.replace(',', '.');
            });

            $("input[type='text']").on("blur", function () {
                $("input[type='text']").val(function (index, value) {
                    return value.replace(',','.');
                });
            });
        });
    </script>
}
