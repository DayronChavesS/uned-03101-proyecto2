@using chaves_dayron_proyecto2_3101.Models
@model Tuple<List<SelectListItem>, reunion>
@{
    ViewBag.Title = "Agendar Reunion";
    string currentDate = DateTime.Today.ToString("yyyy-MM-dd");
}

<h2>Agendar una nueva reunion</h2>


@using (Html.BeginForm("CrearReunion", "Home", FormMethod.Post, new { id = "MyForm" }))
{
    @Html.AntiForgeryToken()

<div class="form-horizontal">
    <hr />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <!--Para ser capaces de validar en controlador en POST y recargar la vista.-->
    @{
        int i = 0;
        foreach (var item in Model.Item1)
        {
            @Html.HiddenFor(model => model.Item1[i].Text)
            @Html.HiddenFor(model => model.Item1[i].Value)
            i++;
        }
    }

    @Html.HiddenFor(model => @Model.Item2.reunion_id)

    <div class="form-group">
        @Html.LabelFor(model => @Model.Item2.empleado_id, htmlAttributes: new { @class = "control-label col-md-2" })
        <div class="col-md-10">
            @Html.DropDownListFor(model => @Model.Item2.empleado_id, @Model.Item1)
            @Html.ValidationMessageFor(model => @Model.Item2.empleado_id, "", new { @class = "text-danger" })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(model => @Model.Item2.fecha, htmlAttributes: new { @class = "control-label col-md-2" })
        <div class="col-md-10">
            @Html.TextBoxFor(model => @Model.Item2.fecha, new { @Type = "date", @Min = @currentDate })
            @Html.ValidationMessageFor(model => @Model.Item2.fecha, "", new { @class = "text-danger" })
        </div>
    </div>
    <br />
    <div class="form-group">
        @Html.LabelFor(model => @Model.Item2.hora_inicio, htmlAttributes: new { @class = "control-label col-md-2" })
        <div class="col-md-10">
            @Html.TextBoxFor(model => @Model.Item2.hora_inicio, new { type = "time" })
            @Html.ValidationMessageFor(model => @Model.Item2.hora_inicio, "", new { @class = "text-danger" })
            @Html.ValidationMessage("HoraInicio", new { @class = "text-danger" })
        </div>
    </div>
    <br />
    <div class="form-group">
        @Html.LabelFor(model => @Model.Item2.hora_fin, htmlAttributes: new { @class = "control-label col-md-2" })
        <div class="col-md-10">
            @Html.TextBoxFor(model => @Model.Item2.hora_fin, new { type = "time" })
            @Html.ValidationMessageFor(model => @Model.Item2.hora_fin, "", new { @class = "text-danger" })
        </div>
    </div>

    <br />

    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <input type="submit" value="Agendar Reunion" class="btn btn-primary btn-md" />
        </div>
        <a style="color:red"><small><i>Esta accion se reportará.</i></small></a>
    </div>
</div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
