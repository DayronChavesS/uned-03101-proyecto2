@model chaves_dayron_proyecto2_3101.Models.turno

@{
    ViewBag.Title = "Cambiar Turno";
}

<h2>Cambiar el Turno</h2>


@using (Html.BeginForm("UpdateTurno", "Home", FormMethod.Post))
{
    @Html.AntiForgeryToken()

<div class="form-horizontal">
    <hr />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    @Html.HiddenFor(model => model.empleado_id)

<div class="form-group">
    @Html.LabelFor(model => model.tiempo_inicio, htmlAttributes: new { @class = "control-label col-md-2" })
    <div class="col-md-10">
        @Html.EditorFor(model => model.tiempo_inicio, new { htmlAttributes = new { @class = "form-control", @Type = "time" } })
    </div>
    @Html.ValidationMessageFor(model => model.tiempo_inicio, "", new { @class = "text-danger" })
    @Html.ValidationMessage("HoraInicio", new { @class = "text-danger" })
</div>

    <br />

    <div class="form-group">
        @Html.LabelFor(model => model.tiempo_fin, htmlAttributes: new { @class = "control-label col-md-2" })
        <div class="col-md-10">
            @Html.EditorFor(model => model.tiempo_fin, new { htmlAttributes = new { @class = "form-control", @Type = "time" } })
        </div>
        @Html.ValidationMessageFor(model => model.tiempo_fin, "", new { @class = "text-danger" })
    </div>

    <br />

    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <input type="submit" value="Aplicar Cambios" class="btn btn-primary btn-md" />
        </div>
        <a style="color:red"><small><i>Esta accion se reportará.</i></small></a>
    </div>
</div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
