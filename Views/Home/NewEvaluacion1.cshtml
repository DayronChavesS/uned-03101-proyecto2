@using chaves_dayron_proyecto2_3101.Models
@model Tuple<List<SelectListItem>, int>
@{
    ViewBag.Title = "NewEvaluacion1";
}

<h2>Seleccione el empleado</h2>

@using (Html.BeginForm("NewEvaluacion1", "Home", FormMethod.Post))
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />

        <div class="form-group">
            <div class="col-md-10">
                @Html.DropDownListFor(model => model.Item2, @Model.Item1)
            </div>
        </div>

        <br />

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Continuar »" class="btn btn-primary btn-md" />
            </div>
        </div>
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}